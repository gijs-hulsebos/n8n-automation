    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nfor (let item of items) {\n  const requests = [];\n  let currentIndex = 1;\n\n  // Dynamische Unsplash image (met tijdstempel voor variatie)\n  const imageUrl = `https://images.unsplash.com/photo-1485827404703-89b55fcc595e?auto=format&fit=crop&q=80&w=1000&sig=${new Date().getTime()}`;\n\n  // 1. VOEG AFBEELDING TOE\n  requests.push({\n    insertInlineImage: {\n      location: { index: 1 },\n      uri: imageUrl,\n      objectSize: {\n        width: { magnitude: 450, unit: 'PT' },\n        height: { magnitude: 250, unit: 'PT' }\n      }\n    }\n  });\n  currentIndex += 1; \n\n  // Helper voor tekst\n  const addText = (text, style = null) => {\n    if (!text) return;\n    const start = currentIndex;\n    requests.push({ insertText: { location: { index: currentIndex }, text: text } });\n    currentIndex += text.length;\n    \n    if (style === 'H1') {\n      requests.push({\n        updateParagraphStyle: {\n          range: { startIndex: start, endIndex: currentIndex },\n          paragraphStyle: { namedStyleType: 'HEADING_1' },\n          fields: 'namedStyleType'\n        }\n      });\n    }\n  };\n\n  // VERBETERDE LINK FUNCTIE\n  const addLink = (url) => {\n    if (!url || !url.startsWith('http')) return; // Check of het echt een URL is\n    const label = \"Read full article\";\n    const linkText = `\\n${label}\\n\\n`;\n    const start = currentIndex + 1; // +1 om de \\n over te slaan voor de styling\n    \n    requests.push({ insertText: { location: { index: currentIndex }, text: linkText } });\n    \n    requests.push({\n      updateTextStyle: {\n        range: { startIndex: start, endIndex: start + label.length },\n        textStyle: { \n          link: { url: url.trim() }, \n          // Kleur moet 3 componenten hebben (red, green, blue) tussen 0 en 1\n          foregroundColor: { color: { rgbColor: { red: 0.1, green: 0.3, blue: 0.8 } } }, \n          underline: true \n        },\n        fields: 'link,foregroundColor,underline'\n      }\n    });\n    currentIndex += linkText.length;\n  };\n\n  const cleanFormat = (text) => text ? text.replace(/[#*]/g, '').trim() : \"\";\n\n  // --- PAGINA 1: COVER ---\n  addText(\"\\n\\nSTRATEGIC AI INTELLIGENCE REPORT\\n\", 'H1');\n  addText(`\\nPrepared by: Gijs Hulsebos\\nDate: ${new Date().toLocaleDateString('nl-NL')}\\n`);\n  \n  requests.push({ insertPageBreak: { location: { index: currentIndex } } });\n  currentIndex += 1;\n\n  // --- PAGINA 2, 3, 4 ---\n  const sections = [\n    { title: \"👔 I. CEO & STRATEGY\", content: item.json.ceo_text },\n    { title: \"📈 II. MARKETING & GROWTH\", content: item.json.marketing_text },\n    { title: \"👥 III. HR & TALENT\", content: item.json.hr_text }\n  ];\n\n  sections.forEach((sec, idx) => {\n    addText(`${sec.title}\\n`, 'H1');\n    const articles = sec.content.split('###').filter(a => a.trim().length > 0);\n    \n    articles.forEach(art => {\n      // SLIMMERE LINK EXTRACTIE: Zoek alles wat met http begint\n      const urlRegex = /(https?:\\/\\/[^\\s\\)\\*]+)/g;\n      const foundLinks = art.match(urlRegex);\n      const cleanArtText = art.split(/Source:/gi)[0]; // Pak alleen de tekst voor \"Source:\"\n      \n      addText(`\\n${cleanFormat(cleanArtText)}\\n`);\n      \n      if (foundLinks && foundLinks.length > 0) {\n        // Pak de laatste link uit het artikel (vaak de bron)\n        addLink(foundLinks[foundLinks.length - 1]);\n      } else {\n        addText(\"\\n\");\n      }\n    });\n\n    if (idx < sections.length - 1) {\n      requests.push({ insertPageBreak: { location: { index: currentIndex } } });\n      currentIndex += 1;\n    }\n  });\n\n  addText(\"\\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\\n\");\n  addText(\"© 2026 | Gijs Hulsebos Autonomous Intelligence\");\n\n  item.json.googleApiBody = { requests: requests };\n}\n\nreturn items;"
      },
