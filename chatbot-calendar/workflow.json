    {
      "parameters": {
        "jsCode": "// Pak de tekst van de AI\nlet text = items[0].json.output;\n\n// Zoek naar de specifieke links in de tekst\nconst githubLink = text.match(/https:\\/\\/github\\.com\\/[^\\s\\)]+/g);\nconst speedLink = text.match(/https:\\/\\/pagespeed\\.web\\.dev\\/[^\\s\\)]+/g);\n\n// Maak een 'metadata' object aan voor de frontend\nconst metadata = {\n  buttons: []\n};\n\nif (githubLink) metadata.buttons.push({ label: \"View Code\", url: githubLink[0] });\nif (speedLink) metadata.buttons.push({ label: \"PageSpeed\", url: speedLink[0] });\n\n// Stuur de schone tekst + de buttons door\nreturn {\n  output: text.split('👉')[0], // Optioneel: strip de tekst-links weg zodat alleen de buttons overblijven\n  metadata: metadata\n};"
      },
